# android/keystore.properties.example
# Copy this file to android/keystore.properties (which is gitignored) and fill in real values.
# See TF-001 in specs/001-sky-defense-core/tasks-store-publishing.md for the keytool command.
#
# storeFile path is relative to android/app/ (the module directory).
# Two levels up from android/app/ lands at the project root (IronwallSky/).
storeFile=../../ironwallsky-release.jks
storePassword=REPLACE_WITH_YOUR_STORE_PASSWORD
keyAlias=ironwallsky
# IMPORTANT: For PKCS12 keystores (default since Java 9), keyPassword must
# match storePassword. Use the same value for both.
keyPassword=REPLACE_WITH_YOUR_STORE_PASSWORD
