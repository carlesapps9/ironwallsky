# AdMob App IDs (from AdMob console → Apps)
# Format: ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY
VITE_ADMOB_APP_ID_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY
VITE_ADMOB_APP_ID_IOS=ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY

# AdMob Ad Unit IDs (from AdMob console → Ad units)
# Format: ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
VITE_ADMOB_INTERSTITIAL_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
VITE_ADMOB_REWARDED_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
VITE_ADMOB_INTERSTITIAL_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
VITE_ADMOB_REWARDED_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY

# Rewarded ad units for Revive Shield and Score Doubler (dedicated placements)
# Create 4 ad units in AdMob: iws-android-revive, iws-android-double, iws-ios-revive, iws-ios-double
VITE_ADMOB_REVIVE_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
VITE_ADMOB_DOUBLE_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
VITE_ADMOB_REVIVE_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
VITE_ADMOB_DOUBLE_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
